-- [ Functions ] --
local function GetNearbyMusic()
    local detected = {}
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("Sound") and v.Playing and v.SoundId:match("%d+") then
            local id = v.SoundId:match("%d+")
            if not table.find(detected, id) then
                table.insert(detected, id)
            end
        end
    end
    return detected
end

local function LoadStudio(name)
    for _, item in pairs(Scroll:GetChildren()) do
        if item:IsA("TextButton") then item:Destroy() end
    end
    
    Title.Text = name
    MainMenu.Visible = false
    MusicPage.Visible = true
    BackBtn.Visible = true
    
    local ids = (name == "ขโมยเพลงรอบข้าง") and GetNearbyMusic() or StudioData[name]
    Scroll.CanvasSize = UDim2.new(0, 0, 0, #ids * 45)
    
    for _, id in pairs(ids) do
        local btn = Instance.new("TextButton", Scroll)
        btn.Size = UDim2.new(1, -10, 0, 40)
        btn.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
        btn.Text = "โหลด... ["..id.."]"
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        btn.TextSize = 10
        Instance.new("UICorner", btn)
        
        task.spawn(function()
            local success, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(id)) end)
            if success then
                btn.Text = info.Name
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end)
        
        btn.MouseButton1Click:Connect(function()
            IdBox.Text = id
            setclipboard(id)
            UniversalPlay(id)
        end)
    end
end

