-- [ 🎹 Private Player Logic ] --
local function UniversalPlay(id)
    if not id or id == "" then return end
    local re = game:GetService("ReplicatedStorage"):WaitForChild("RE", 5)
    if re and re:FindFirstChild("PlayerToolEvent") then
        -- ใช้โครงสร้าง Args ตามที่คุณส่งมาให้ [4] = true
        local playArgs = {
            "ToolMusicText",
            tostring(id),
            [4] = true
        }
        re.PlayerToolEvent:FireServer(unpack(playArgs))
    end
end

