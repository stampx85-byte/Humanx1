-- [ 🛡️ ULTIMATE ANTI-LOGGER & SPOOFER ] --
local namecall
namecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod():lower()
    
    if _G.p and not checkcaller() and (method == "fireserver" or method == "invokeapi") then
        if tostring(self) == "PlayerToolEvent" or args[1] == "ToolMusicText" then
            local realId = args[2]
            
            task.spawn(function()
                -- ส่ง ID จริงตามโครงสร้าง args ที่คุณให้มา
                namecall(self, "ToolMusicText", realId, nil, true) 
            end)
            
            args[2] = getgenv().replacement or "nil"
            return namecall(self, unpack(args))
        end
    end
    return namecall(self, ...)
end)

