local function createButton(id)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(1, -5, 0, 40)
    btn.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
    btn.Text = "Fetching..."
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 12
    Instance.new("UICorner", btn)

    task.spawn(function()
        local success, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(id)) end)
        if success and info then
            btn.Text = info.Name .. " [" .. id .. "]"
        else
            btn.Text = "Unknown Asset [" .. id .. "]"
        end
    end)

    btn.MouseButton1Click:Connect(function()
        setclipboard(id)
        local old = btn.Text
        btn.Text = "COPIED!"
        btn.TextColor3 = Color3.fromRGB(0, 255, 0)
        task.wait(0.5)
        btn.Text = old
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
end

for _, id in pairs(AudioList) do
    createButton(id)
end

