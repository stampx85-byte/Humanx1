-- [ NEW: ระบบ Namecall Hook (แก้ไขจากต้นฉบับให้เสถียรขึ้น) ] --
local namecall
namecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod():lower()
    
    if _G.p and not checkcaller() and method == "fireserver" then
        -- กั้น Argument ที่ 2 (ตำแหน่ง ID เพลงในสคิปต์ของคุณ)
        if args[1] == "ToolMusicText" then
            args[2] = getgenv().replacement or "nil"
        else
            args[1] = getgenv().replacement or "nil"
        end
        return namecall(self, unpack(args))
    end
    return namecall(self, ...)
end)

