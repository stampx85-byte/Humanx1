-- [ ✨ Animation Function ] --
local function ClickAnim(obj)
    local originalSize = obj.Size
    local originalColor = obj.BackgroundColor3
    
    local clickTween = TweenService:Create(obj, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(originalSize.X.Scale * 0.95, originalSize.X.Offset, originalSize.Y.Scale * 0.95, originalSize.Y.Offset),
        BackgroundColor3 = Color3.fromRGB(originalColor.R * 255 + 20, originalColor.G * 255 + 20, originalColor.B * 255 + 20)
    })
    
    local releaseTween = TweenService:Create(obj, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = originalSize,
        BackgroundColor3 = originalColor
    })
    
    clickTween:Play()
    clickTween.Completed:Connect(function() releaseTween:Play() end)
end

-- [ 🎹 Private Player Logic ] --
local RecentSongs = {} 

local function UniversalPlay(id)
    if not id or id == "" then return end
    
    local existIndex = table.find(RecentSongs, id)
    if existIndex then table.remove(RecentSongs, existIndex) end
    table.insert(RecentSongs, 1, id)
    if #RecentSongs > 20 then table.remove(RecentSongs, 21) end 

    local re = game:GetService("ReplicatedStorage"):WaitForChild("RE", 5)
    if re and re:FindFirstChild("PlayerToolEvent") then
        local playArgs = {"ToolMusicText", tostring(id), [4] = true}
        re.PlayerToolEvent:FireServer(unpack(playArgs))
    end
end

