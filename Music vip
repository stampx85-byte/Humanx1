    local detected = {}
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("Sound") and v.Playing and v.SoundId:match("%d+") then
            local id = v.SoundId:match("%d+")
            if not table.find(detected, id) then table.insert(detected, id) end
        end
    end
    return detected
end

local function LoadStudio(name)
    for _, item in pairs(Scroll:GetChildren()) do
        if item:IsA("Frame") then item:Destroy() end
    end
    Title.Text = name
    MainMenu.Visible = false
    MusicPage.Visible = true
    BackBtn.Visible = true
    TotalLabel.Visible = false
    
    local ids = {}
    if name == "ขโมยเพลงรอบข้าง" then ids = GetNearbyMusic()
    elseif name == "รายการโปรด ⭐" then ids = Favorites
    elseif name == "เล่นล่าสุด 🕒" then ids = RecentSongs
    else ids = StudioData[name] end
    
    Scroll.CanvasSize = UDim2.new(0, 0, 0, #ids * 45)
    for _, id in pairs(ids) do
        local container = Instance.new("Frame", Scroll)
        container.Size = UDim2.new(1, -10, 0, 40)
        container.BackgroundTransparency = 1
        
        local btn = Instance.new("TextButton", container)
        btn.Size = UDim2.new(0.8, -5, 1, 0)
        btn.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
        btn.Text = "โหลด... ["..id.."]"
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        btn.TextSize = 10
        Instance.new("UICorner", btn)
        
        local favBtn = Instance.new("TextButton", container)
        favBtn.Size = UDim2.new(0.2, 0, 1, 0)
        favBtn.Position = UDim2.new(0.8, 0, 0, 0)
        favBtn.BackgroundColor3 = table.find(Favorites, id) and Color3.fromRGB(150, 150, 0) or Color3.fromRGB(50, 50, 50)
        favBtn.Text = "⭐"
        favBtn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", favBtn)

        task.spawn(function()
            local success, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(id)) end)
            if success then btn.Text = info.Name btn.TextColor3 = Color3.fromRGB(255, 255, 255) end
        end)
        
        btn.MouseButton1Click:Connect(function() 
            ClickAnim(btn)
            setclipboard(id) 
            UniversalPlay(id) 
        end)
        
        favBtn.MouseButton1Click:Connect(function()
            ClickAnim(favBtn)
            local index = table.find(Favorites, id)
            if index then
                table.remove(Favorites, index)
                favBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                if name == "รายการโปรด ⭐" then container:Destroy() end
            else
                table.insert(Favorites, id)
                favBtn.BackgroundColor3 = Color3.fromRGB(150, 150, 0)
            end
            SaveFavs()
        end)
    end
end

