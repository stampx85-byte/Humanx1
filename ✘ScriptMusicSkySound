-- [ 💾 Data Saving System ] --
local fileName = "SkySound_Favs.json"
local timeFileName = "SkySound_Runtime.json"
local Favorites = {}
local totalRuntime = 0

local function SaveData()
    local success, content = pcall(function() return HttpService:JSONEncode(Favorites) end)
    if success then writefile(fileName, content) end
end

local function SaveTime()
    writefile(timeFileName, tostring(totalRuntime))
end

local function LoadData()
    if isfile(fileName) then
        local success, content = pcall(function() return HttpService:JSONDecode(readfile(fileName)) end)
        if success then Favorites = content end
    end
    if isfile(timeFileName) then
        totalRuntime = tonumber(readfile(timeFileName)) or 0
    end
end
LoadData()

-- [[ ✨ NEW ANIMATION HELPERS ]] --
local function ClickAnim(obj)
    local originalSize = obj.Size
    obj:TweenSize(UDim2.new(originalSize.X.Scale, originalSize.X.Offset * 0.9, originalSize.Y.Scale, originalSize.Y.Offset * 0.9), "Out", "Quad", 0.1, true)
    task.wait(0.1)
    obj:TweenSize(originalSize, "Out", "Back", 0.2, true)
end

local function CopyEffect(pos)
    local label = Instance.new("TextLabel", ScreenGui)
    label.Size = UDim2.new(0, 80, 0, 20)
    label.Position = UDim2.new(0, pos.X, 0, pos.Y - 20)
    label.BackgroundTransparency = 1
    label.Text = "COPIED!"
    label.TextColor3 = Color3.fromRGB(255, 255, 0)
    label.Font = Enum.Font.Arcade
    label.TextSize = 14
    TweenService:Create(label, TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = label.Position - UDim2.new(0,0,0,30), TextTransparency = 1}):Play()
    game:GetService("Debris"):AddItem(label, 0.7)
end

-- [ 🔊 Audio Preview System ] --
local currentSound = nil
local currentPlayBtn = nil
local waveConnection = nil

local function PlayPreview(id, btn)
    if currentSound and currentSound.SoundId == "rbxassetid://"..id then
        if waveConnection then waveConnection:Disconnect() end
        currentSound:Stop()
        currentSound:Destroy()
        currentSound = nil
        btn.Image = "rbxassetid://6031075931"
        btn.Size = UDim2.new(0, 25, 0, 25)
        return
    end
    if currentSound then 
        if waveConnection then waveConnection:Disconnect() end
        currentSound:Stop() 
        currentSound:Destroy() 
        if currentPlayBtn then 
            currentPlayBtn.Image = "rbxassetid://6031075931" 
            currentPlayBtn.Size = UDim2.new(0, 25, 0, 25)
        end
    end
    currentSound = Instance.new("Sound")
    currentSound.SoundId = "rbxassetid://"..id
    currentSound.Parent = game:GetService("SoundService")
    currentSound.Volume = 1
    currentSound:Play()
    currentPlayBtn = btn
    btn.Image = "rbxassetid://6023455125"
    waveConnection = RunService.RenderStepped:Connect(function()
        if currentSound and currentSound.IsPlaying then
            local scale = 1 + (math.sin(tick() * 10) * 0.2)
            btn.Size = UDim2.new(0, 25 * scale, 0, 25 * scale)
        else
            if waveConnection then waveConnection:Disconnect() end
        end
    end)
    currentSound.Ended:Connect(function()
        btn.Image = "rbxassetid://6031075931"
        btn.Size = UDim2.new(0, 25, 0, 25)
        if currentSound then currentSound:Destroy() currentSound = nil end
    end)
end

