local function LoadMusic(cat)
    for _, v in pairs(Container:GetChildren()) do if v:IsA("Frame") or v:IsA("TextButton") then v:Destroy() end end
    BackBtn.Visible = true
    Title.Text = cat
    AddFrame.Visible = (cat == "FAVORITES ⭐️")
    Container.Position = (cat == "FAVORITES ⭐️") and UDim2.new(0, 8, 0, 90) or UDim2.new(0, 8, 0, 60)
    
    local listSource = (cat == "FAVORITES ⭐️") and Favorites or CustomMusic[cat]
    
    for i, id in pairs(listSource) do
        local Card = Instance.new("Frame", Container)
        Card.Size = UDim2.new(1, 0, 0, 75)
        Card.BackgroundColor3 = Color3.fromRGB(18, 2, 2)
        Card.BackgroundTransparency = 1 -- Start transparent for animation
        Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 8)
        Instance.new("UIStroke", Card).Color = Color3.fromRGB(60, 0, 0)
        
        -- Smooth Fade-In Animation
        TweenService:Create(Card, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, i * 0.05), {BackgroundTransparency = 0}):Play()

        local Img = Instance.new("ImageLabel", Card)
        Img.Size = UDim2.new(0, 55, 0, 55)
        Img.Position = UDim2.new(0, 8, 0.5, -27.5)
        Img.Image = "https://www.roblox.com/asset-thumbnail/image?assetId="..id.."&width=420&height=420&format=png"
        Instance.new("UICorner", Img)

        local Name = Instance.new("TextLabel", Card)
        Name.Size = UDim2.new(1, -75, 0, 15)
        Name.Position = UDim2.new(0, 70, 0, 10)
        Name.Text = "Loading..."
        Name.TextColor3 = Color3.new(1, 1, 1)
        Name.Font = Enum.Font.Arcade
        Name.TextSize = 10
        Name.BackgroundTransparency = 1
        Name.TextXAlignment = Enum.TextXAlignment.Left

        local CreatedLabel = Instance.new("TextLabel", Card)
        CreatedLabel.Size = UDim2.new(1, -75, 0, 12)
        CreatedLabel.Position = UDim2.new(0, 70, 0, 25)
        CreatedLabel.Text = "Date: --/--/--"
        CreatedLabel.TextColor3 = Color3.fromRGB(180, 0, 0)
        CreatedLabel.Font = Enum.Font.Arcade
        CreatedLabel.TextSize = 8
        CreatedLabel.BackgroundTransparency = 1
        CreatedLabel.TextXAlignment = Enum.TextXAlignment.Left

        local CopyBtn = Instance.new("TextButton", Card)
        CopyBtn.Size = UDim2.new(0, 45, 0, 20)
        CopyBtn.Position = UDim2.new(0, 70, 0, 45)
        CopyBtn.BackgroundColor3 = Color3.fromRGB(60, 0, 0)
        CopyBtn.Text = "COPY"
        CopyBtn.TextColor3 = Color3.new(1,1,1)
        CopyBtn.Font = Enum.Font.Arcade
        CopyBtn.TextSize = 8
        Instance.new("UICorner", CopyBtn)

        local ActionBtn = Instance.new("TextButton", Card)
        ActionBtn.Size = UDim2.new(0, 45, 0, 20)
        ActionBtn.Position = UDim2.new(0, 120, 0, 45)
        ActionBtn.BackgroundColor3 = (cat == "FAVORITES ⭐️") and Color3.fromRGB(40, 40, 40) or Color3.fromRGB(150, 0, 0)
        ActionBtn.Text = (cat == "FAVORITES ⭐️") and "DEL" or "SAVE"
        ActionBtn.TextColor3 = Color3.new(1,1,1)
        ActionBtn.Font = Enum.Font.Arcade
        ActionBtn.TextSize = 8
        Instance.new("UICorner", ActionBtn)

        task.spawn(function()
            local success, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(id)) end)
            if success then 
                Name.Text = info.Name 
                CreatedLabel.Text = "Date: " .. string.sub(info.Created, 1, 10)
            end
        end)

        CopyBtn.MouseButton1Click:Connect(function() 
            ClickAnim(CopyBtn)
            setclipboard(id) 
            CopyEffect(Vector2.new(CopyBtn.AbsolutePosition.X, CopyBtn.AbsolutePosition.Y))
        end)
        
        ActionBtn.MouseButton1Click:Connect(function()
            ClickAnim(ActionBtn)
            if cat == "FAVORITES ⭐️" then
                for i,v in ipairs(Favorites) do if v == id then table.remove(Favorites, i) break end end
                SaveData()
                Card:Destroy()
            else
                table.insert(Favorites, id)
                SaveData()
                ActionBtn.Text = "OK" task.wait(0.5) ActionBtn.Text = "SAVE"
            end
        end)

        local Play = Instance.new("ImageButton", Card)
        Play.Size = UDim2.new(0, 25, 0, 25)
        Play.Position = UDim2.new(1, -35, 1, -35)
