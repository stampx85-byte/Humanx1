-- [[ LOGIC: เจาะไอดีและขโมย ]]

-- 1. ฟังก์ชันหาตัวเหยื่อจากชื่อหรือไอดี
StealAction.MouseButton1Click:Connect(function()
    local text = TargetInput.Text
    local targetPlayer = nil
    
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #text) == text:lower() or tostring(p.UserId) == text then
            targetPlayer = p
            break
        end
    end
    
    if targetPlayer then
        VictimName.Text = targetPlayer.DisplayName
        VictimImage.Image = Players:GetUserThumbnailAsync(targetPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
        
        -- เจาะหาเพลงในตัวเหยื่อ
        local foundSong = false
        for _, v in pairs(targetPlayer.Character:GetDescendants()) do
            if v:IsA("Sound") and v.Playing then
                SongIDBox.Text = v.SoundId:match("%d+")
                SongStatus.Text = "STOLEN FROM: " .. targetPlayer.Name
                foundSong = true
            end
        end
        if not foundSong then SongIDBox.Text = "NO SONG PLAYING"; SongStatus.Text = "TARGET HAS NO MUSIC" end
    else
        VictimName.Text = "NOT FOUND"
    end
end)

-- 2. ฟังก์ชันส่งค่าเข้าเซิร์ฟเวอร์ (ตามสคิปต์ที่คุณให้มา)
PlayAction.MouseButton1Click:Connect(function()
    local args = {
        "ToolMusicText",
        SongIDBox.Text,
        [4] = true
    }
    local re = RS:FindFirstChild("RE") and RS.RE:FindFirstChild("PlayerToolEvent")
    if re then
        re:FireServer(unpack(args))
        PlayAction.Text = "HACKED!"
        task.wait(1)
        PlayAction.Text = "FIRE TO SERVER"
    end
end)

