-- [ 🔥 THE REAL SCANNER (Modified for Speed) ]
local function CreateCard(player, id, location)
    if not id or CapturedIDs[id] or id:sub(1,2) == "55" then return end
    CapturedIDs[id] = true

    local Card = Instance.new("Frame", AudioScroll)
    Card.Size = UDim2.new(1, -10, 0, 50)
    Card.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
    Instance.new("UICorner", Card)

    local Info = Instance.new("TextLabel", Card)
    Info.Size = UDim2.new(1, -60, 1, 0)
    Info.Position = UDim2.new(0, 10, 0, 0)
    Info.Text = "👤 " .. (player and player.DisplayName or "System") .. "\n🆔 " .. id .. "\n📍 " .. location
    Info.TextColor3 = Color3.new(1, 1, 1)
    Info.Font = Enum.Font.Code
    Info.TextSize = 9
    Info.TextXAlignment = Enum.TextXAlignment.Left
    Info.BackgroundTransparency = 1

    local Copy = Instance.new("TextButton", Card)
    Copy.Size = UDim2.new(0, 55, 0, 30)
    Copy.Position = UDim2.new(1, -60, 0.5, -15)
    Copy.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    Copy.Text = "GRAB"
    Copy.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", Copy)
    Copy.MouseButton1Click:Connect(function()
        setclipboard(tostring(id))
        Copy.Text = "STOLEN"
        task.wait(0.5)
        Copy.Text = "GRAB"
    end)
    AudioScroll.CanvasSize = UDim2.new(0, 0, 0, AS_Layout.AbsoluteContentSize.Y)
    
    Notify("NEW AUDIO DETECTED", "Player: " .. (player and player.Name or "Unknown") .. " | ID: " .. id)
end

-- [ 🔥 ระบบเจาะระดับเสี้ยววินาที ]
local function UltimateScan(target)
    local targets = target and {target} or Players:GetPlayers()
    for _, p in pairs(targets) do
        pcall(function()
            local areas = {p.Character, p.Backpack, p:FindFirstChild("PlayerGui"), p:FindFirstChild("PlayerScripts")}
            for _, area in pairs(areas) do
                if area then
                    for _, obj in pairs(area:GetDescendants()) do
                        if obj:IsA("Sound") and not obj:IsDescendantOf(game:GetService("RobloxReplicatedStorage")) then
                            local id = obj.SoundId:match("%d+")
                            if id and #id >= 6 then CreateCard(p, id, area.Name) end
                        end
                    end
                end
            end
        end)
    end
end

