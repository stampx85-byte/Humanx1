-- [ SNIFFER CORE - UPDATED FILTER ]
local Captured = {}
local function NewEntry(id, name)
    if Captured[id] then return end
    Captured[id] = true
    
    local Frame = Instance.new("Frame", LogScroll)
    Frame.Size = UDim2.new(1, -6, 0, 35)
    Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Frame.BorderColor3 = Color3.fromRGB(40, 40, 40)

    local InfoText = Instance.new("TextLabel", Frame)
    InfoText.Text = " > " .. name .. " [" .. id .. "]"
    InfoText.Size = UDim2.new(0.75, 0, 1, 0)
    InfoText.Position = UDim2.new(0, 5, 0, 0)
    InfoText.TextColor3 = Color3.fromRGB(220, 220, 220)
    InfoText.Font = FONT_STYLE
    InfoText.TextSize = 11
    InfoText.BackgroundTransparency = 1
    InfoText.TextXAlignment = Enum.TextXAlignment.Left
    InfoText.TextTruncate = Enum.TextTruncate.AtEnd

    local CopyBtn = Instance.new("TextButton", Frame)
    CopyBtn.Text = "[GET]"
    CopyBtn.Size = UDim2.new(0.2, 0, 0.7, 0)
    CopyBtn.Position = UDim2.new(0.78, 0, 0.15, 0)
    CopyBtn.BackgroundColor3 = SECONDARY_BG
    CopyBtn.TextColor3 = ACCENT_COLOR
    CopyBtn.Font = FONT_STYLE
    CopyBtn.TextSize = 10

    CopyBtn.MouseButton1Click:Connect(function()
        setclipboard(id)
        CopyBtn.Text = "[CPY]"
        task.wait(0.5)
        CopyBtn.Text = "[GET]"
    end)

    LogScroll.CanvasSize = UDim2.new(0, 0, 0, LogScroll:FindFirstChildOfClass("UIListLayout").AbsoluteContentSize.Y)
end

local function Scan(obj)
    if obj:IsA("Sound") then
        local id = obj.SoundId:match("%d+")
        if id then
            task.spawn(function()
                local s, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(id)) end)
                if s and info and info.AssetTypeId == 3 then
                    -- กรอง: ไม่ใช่ของเจ้าของแมพ และ ไม่ใช่ของ Roblox Official (ID 1)
                    if info.Creator.Id ~= CreatorID and info.Creator.Id ~= 1 then
                        -- ตรวจสอบว่าเป็นเพลงยาว (ไม่ใช่ Sound Effect สั้นๆ)
                        if obj.TimeLength > 0 or obj.IsLoaded then
                             NewEntry(id, info.Name)
                        end
                    end
                end
            end)
        end
    end
end

ClearBtn.MouseButton1Click:Connect(function()
    for _, v in pairs(LogScroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    Captured = {}
    LogScroll.CanvasSize = UDim2.new(0,0,0,0)
end)

game.DescendantAdded:Connect(Scan)
for _, v in pairs(game:GetDescendants()) do Scan(v) end
