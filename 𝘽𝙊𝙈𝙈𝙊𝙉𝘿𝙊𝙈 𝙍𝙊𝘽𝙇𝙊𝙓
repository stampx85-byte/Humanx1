    local CopyBtn = Instance.new("TextButton", Frame)
    CopyBtn.Text = "[GET]"
    CopyBtn.Size = UDim2.new(0.2, 0, 0.7, 0)
    CopyBtn.Position = UDim2.new(0.78, 0, 0.15, 0)
    CopyBtn.BackgroundColor3 = SECONDARY_BG
    CopyBtn.TextColor3 = ACCENT_COLOR
    CopyBtn.Font = FONT_STYLE
