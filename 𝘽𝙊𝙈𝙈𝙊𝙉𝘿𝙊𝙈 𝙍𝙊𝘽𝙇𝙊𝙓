-- [ BACKEND PIERCE ]
BackendStartBtn.MouseButton1Click:Connect(function()
    local target = BackendSearchInput.Text
    if target == "" then return end
    for _, v in pairs(BackendScroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    task.spawn(function()
        local success, res = pcall(function() return game:HttpGet("https://catalog.roblox.com/v1/search/items/details?category=12&keyword=" .. HttpService:UrlEncode(target) .. "&limit=30") end)
        if success then
            local data = HttpService:JSONDecode(res)
            if data and data.data then for _, item in pairs(data.data) do CreateListEntry(BackendScroll, tostring(item.id), item.name) end end
        end
    end)
end)

-- [ SNIFFER LOGIC ]
local Captured = {}
local function Scan(obj)
    if obj:IsA("Sound") then
        -- ถ้าเปิดโหมดกั้น และเป็น Sound จริงของเรา ให้รีบซ่อน (เบื้องต้น)
        if ProtActive and obj.Parent == Players.LocalPlayer.Character then
            obj.Name = "..." -- ซ่อนชื่อ
        end
        
        local id = obj.SoundId:match("%d+")
        if id and not Captured[id] then
            task.spawn(function()
                local s, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(id)) end)
                if s and info and info.AssetTypeId == 3 then
                    Captured[id] = true
                    CreateListEntry(LogScroll, id, info.Name)
                end
            end)
        end
    end
end

ClearBtn.MouseButton1Click:Connect(function()
    for _, v in pairs(LogScroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    Captured = {}
end)

game.DescendantAdded:Connect(Scan)
for _, v in pairs(game:GetDescendants()) do Scan(v) end

